# PocketBase URL
# 开发环境留空时，默认通过 Vite 代理访问本地 PocketBase
# 如果前端与 PocketBase 不在同一域名，或你要直接访问远程 PocketBase，请显式填写。
VITE_PB_URL=

# Optional map provider key. When set, activity route maps use MapTiler Streets vector tiles
# for sharper labels and richer place names. When omitted, the app falls back to the built-in raster basemap.
# VITE_MAPTILER_KEY=

# Vite dev server / HMR（仅在 Docker、远程开发或反向代理时按需设置）
# VITE_DEV_HOST=0.0.0.0
# VITE_DEV_PORT=5173
# VITE_HMR_HOST=127.0.0.1
# VITE_HMR_PROTOCOL=ws
# VITE_HMR_CLIENT_PORT=5173
