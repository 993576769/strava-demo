## Required: Core server
PORT=8090
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/strava_art_lab
APP_URL=http://127.0.0.1:5173

ACCESS_TOKEN_SECRET=replace-with-a-long-random-string-at-least-32-chars
REFRESH_TOKEN_SECRET=replace-with-a-long-random-string-at-least-32-chars

## Required: GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:8090/api/auth/github/callback

## Recommended: Strava integration
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://127.0.0.1:8090/api/integrations/strava/callback
STRAVA_SCOPES=read,activity:read_all
STRAVA_STATE_SECRET=replace-with-a-long-random-string
STRAVA_WEBHOOK_VERIFY_TOKEN=replace-with-a-webhook-verify-token
STRAVA_TOKEN_ENCRYPTION_KEY=replace-with-another-long-random-string

## Optional: Strava tuning
# STRAVA_HTTP_TIMEOUT_SECONDS=15
# STRAVA_SYNC_PER_PAGE=10
# STRAVA_SYNC_MAX_PAGES=1
# STRAVA_SYNC_MAX_ACTIVITIES=10

## Required for image generation: Doubao / Ark
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_SEEDREAM_MODEL=doubao-seedream-5-0-260128
DOUBAO_IMAGE_SIZE=2K
DOUBAO_OUTPUT_FORMAT=png
DOUBAO_RESPONSE_FORMAT=url
DOUBAO_REQUEST_TIMEOUT_MS=120000

## Required for asset storage: S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_S3_PUBLIC_BASE_URL=

## Optional: Worker / storage tuning
# ART_JOB_POLL_INTERVAL_MS=3000
# ART_WORKER_STALE_PROCESSING_MS=120000
# ART_WORKER_RETRY_DELAY_MS=120000
# ART_WORKER_RATE_LIMIT_RETRY_DELAY_MS=300000
# AWS_SESSION_TOKEN=
# AWS_S3_ENDPOINT=

## Optional: dev-all overrides
# API_BASE_URL=http://127.0.0.1:8090
# API_DEV_STARTUP_TIMEOUT_MS=60000

## Optional: deployment image tags
# FRONTEND_IMAGE=ghcr.io/your-org/strava-art-lab-frontend
# SERVER_IMAGE=ghcr.io/your-org/strava-art-lab-server
# IMAGE_TAG=master
