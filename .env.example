## Deployment images
# FRONTEND_IMAGE=ghcr.io/your-org/vue-pocketbase-template-frontend
# POCKETBASE_IMAGE=ghcr.io/your-org/vue-pocketbase-template-pocketbase
# IMAGE_TAG=master

## PocketBase superuser bootstrap
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me
# PB_HOOKS_WATCH=false

## PocketBase type generation
PB_TYPEGEN_URL=http://127.0.0.1:8090
# PB_TYPEGEN_EMAIL=admin@example.com
# PB_TYPEGEN_PASSWORD=change-me
# PB_TYPEGEN_TOKEN=

## Seed data
PB_SEED_URL=http://127.0.0.1:8090
# PB_SEED_EMAIL=admin@example.com
# PB_SEED_PASSWORD=change-me
# PB_SEED_TOKEN=

## Strava integration
# APP_URL=http://127.0.0.1:5173
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REDIRECT_URI=http://127.0.0.1:8090/api/integrations/strava/callback
# STRAVA_SCOPES=read,activity:read_all
# STRAVA_STATE_SECRET=replace-with-a-long-random-string
# STRAVA_WEBHOOK_VERIFY_TOKEN=replace-with-a-webhook-verify-token
# STRAVA_TOKEN_ENCRYPTION_KEY=optional-separate-encryption-key
# STRAVA_HTTP_TIMEOUT_SECONDS=15
# STRAVA_SYNC_PER_PAGE=10
# STRAVA_SYNC_MAX_PAGES=1
# STRAVA_SYNC_MAX_ACTIVITIES=10

## Art rendering
# ART_RENDER_PROVIDER=mock
# Supported providers: mock, doubao-seedream
# ART_ASSET_UPLOAD_PROVIDER=pocketbase
# ART_ASSET_HELPER_HOST=127.0.0.1
# ART_ASSET_HELPER_PORT=3211
# ART_WORKER_SECRET=local-art-worker-secret
# ART_WORKER_POLL_INTERVAL_MS=3000
# ART_WORKER_FAILURE_BACKOFF_MS=5000
# ART_WORKER_IDLE_HEARTBEAT_MS=30000
# ART_WORKER_STALE_PROCESSING_MS=120000
# ART_WORKER_RETRY_DELAY_MS=120000
# ART_WORKER_RATE_LIMIT_RETRY_DELAY_MS=300000
# ART_WORKER_MAX_CONCURRENT_JOBS=1
# Retryable Jimeng business codes are handled in worker: 50511, 50519, 50429, 50430
# ART_ASSET_BASE_URL=https://your-public-app-host

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_S3_BUCKET=
# AWS_S3_REGION=
# AWS_S3_ENDPOINT=
# AWS_S3_PUBLIC_BASE_URL=
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_SEEDREAM_MODEL=doubao-seedream-5-0-260128
# DOUBAO_IMAGE_SIZE=2K
# DOUBAO_OUTPUT_FORMAT=png
# DOUBAO_RESPONSE_FORMAT=url
# DOUBAO_WATERMARK=true
# DOUBAO_HELPER_HOST=127.0.0.1
# DOUBAO_HELPER_PORT=3211
# DOUBAO_HELPER_TIMEOUT_MS=120000
