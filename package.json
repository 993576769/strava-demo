{
  "name": "strava-art-lab",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "bun run dev:all",
    "dev:web": "cd frontend && bun run dev",
    "dev:server": "bun --watch --no-clear-screen server/src/index.ts",
    "dev:all": "bun scripts/dev-all.mjs",
    "lint": "eslint .",
    "build": "cd frontend && bun run build",
    "preview": "cd frontend && bun run preview",
    "typecheck": "cd frontend && bun run typecheck && cd .. && tsc -p server/tsconfig.json --noEmit",
    "db:generate": "bunx drizzle-kit generate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@hono/node-server": "^1.19.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.5",
    "@types/qs": "^6.15.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.5",
    "drizzle-seed": "^0.3.1",
    "eslint": "^10.2.0",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "hono": "^4.9.6",
    "jose": "^6.1.0",
    "pg": "^8.16.3",
    "qs": "^6.15.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "zod": "^4.1.12"
  }
}
